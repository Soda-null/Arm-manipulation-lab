<mujoco model="planar_2link_arm">
  <!--
    Placeholder MuJoCo model for a planar 2-link arm.
    This XML is intended as a clear starting point for later simulation work.
    Full controller validation will be done in Stage 04.
  -->
  <compiler angle="radian" coordinate="local"/>
  <option timestep="0.002" gravity="0 0 -9.81"/>

  <default>
    <joint type="hinge" axis="0 0 1" damping="0.1"/>
    <geom type="capsule" size="0.035" rgba="0.2 0.4 0.8 1"/>
  </default>

  <worldbody>
    <geom name="floor" type="plane" size="3 3 0.05" rgba="0.9 0.9 0.9 1"/>
    <body name="base" pos="0 0 0.05">
      <geom name="base_geom" type="cylinder" size="0.08 0.04" rgba="0.2 0.2 0.2 1"/>
      <body name="link1" pos="0 0 0">
        <joint name="shoulder" type="hinge" axis="0 0 1" range="-3.14159 3.14159"/>
        <geom name="link1_geom" fromto="0 0 0 1.0 0 0" size="0.035"/>
        <body name="link2" pos="1.0 0 0">
          <joint name="elbow" type="hinge" axis="0 0 1" range="-3.14159 3.14159"/>
          <geom name="link2_geom" fromto="0 0 0 0.7 0 0" size="0.03" rgba="0.8 0.4 0.2 1"/>
          <site name="end_effector" pos="0.7 0 0" size="0.04" rgba="0.1 0.8 0.2 1"/>
        </body>
      </body>
    </body>
    <site name="target" pos="1.0 0.5 0.05" size="0.05" rgba="0.9 0.1 0.1 1"/>
  </worldbody>

  <actuator>
    <motor name="shoulder_motor" joint="shoulder" gear="1"/>
    <motor name="elbow_motor" joint="elbow" gear="1"/>
  </actuator>
</mujoco>
