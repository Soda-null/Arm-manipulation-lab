<mujoco model="simple_spatial_arm_motor">
  <compiler angle="radian" inertiafromgeom="true"/>
  <option timestep="0.002" gravity="0 0 -9.81"/>

  <default>
    <joint damping="0.6" armature="0.03"/>
    <geom contype="0" conaffinity="0" density="350" rgba="0.25 0.36 0.48 1"/>
    <motor ctrllimited="true" ctrlrange="-240 240"/>
  </default>

  <worldbody>
    <light pos="0 0 3"/>
    <geom name="floor" type="plane" size="3 3 0.02" rgba="0.92 0.92 0.9 1"/>
    <site name="target" pos="1.25 0.35 0.75" size="0.045" rgba="1 0.1 0.1 1"/>
    <body name="base" pos="0 0 0.25">
      <joint name="base_yaw" type="hinge" axis="0 0 1" range="-3.14 3.14"/>
      <geom name="base_geom" type="cylinder" size="0.18 0.22" rgba="0.18 0.24 0.32 1"/>
      <body name="upper_arm" pos="0 0 0.35">
        <joint name="shoulder_pitch" type="hinge" axis="0 1 0" range="-2.2 2.2"/>
        <geom name="shoulder_hub" type="sphere" size="0.09" rgba="0.1 0.62 0.58 1"/>
        <geom name="upper_arm_geom" type="capsule" fromto="0 0 0 1.0 0 0" size="0.045" rgba="0.85 0.66 0.25 1"/>
        <body name="forearm" pos="1.0 0 0">
          <joint name="elbow_pitch" type="hinge" axis="0 1 0" range="-2.6 2.6"/>
          <geom name="elbow_hub" type="sphere" size="0.075" rgba="0.1 0.62 0.58 1"/>
          <geom name="forearm_geom" type="capsule" fromto="0 0 0 0.8 0 0" size="0.04" rgba="0.85 0.66 0.25 1"/>
          <site name="end_effector" pos="0.8 0 0" size="0.045" rgba="0 0 0 1"/>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="base_yaw_motor" joint="base_yaw"/>
    <motor name="shoulder_pitch_motor" joint="shoulder_pitch"/>
    <motor name="elbow_pitch_motor" joint="elbow_pitch"/>
  </actuator>
</mujoco>
